{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/vercel",
  "functions": {
    "api/orders.ts": {
      "maxDuration": 30
    },
    "api/send-confirmation.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
